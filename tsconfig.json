{
	"compilerOptions": {
		"target": "ES2021",
		"module": "CommonJS",
		"lib": ["ES2021"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"outDir": "./dist",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "**/*.test.ts", "generated", "dist"]
}
